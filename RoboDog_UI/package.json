{
  "name": "spot-micro-control",
  "version": "1.0.0",
  "description": "SPOT-MICRO Robot Dog Control Interface",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "listen:telemetry": ".\\.venv\\Scripts\\python.exe rosbridge_listener.py",
    "build": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.spotmicro.control",
    "productName": "SPOT-MICRO Control",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "roslib": "^1.4.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "author": "SPOT-MICRO Project",
  "license": "MIT"
}
